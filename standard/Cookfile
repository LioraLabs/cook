# Cookfile for the Cook Standard.
#
# Imported by the top-level Cookfile as `standard`. Chores here run
# with cwd = ./standard/, so paths are relative to this directory.
#
# `lint` and `against-tag` route through cook_modules/checks.lua, which
# is the in-repo replacement for the bash scripts that used to live in
# standard/scripts/.
#
# `against-tag` reads VERSION from
#   cook standard.against-tag --set VERSION=X.Y
# and defaults to the current contents of standard/VERSION.

use checks

chore build
    pnpm build

chore lint
    checks.lint_keywords()

chore host
    @pnpm host

chore against-tag
    >{
        local version = cook.env.VERSION
        if not version or version == "" then
            version = fs.read("VERSION"):gsub("%s+$", "")
        end
        checks.against_tag(version)
    }

chore retag
    V="${VERSION:-$(cat VERSION)}" && git tag --force "cs-standard/v$V" HEAD
