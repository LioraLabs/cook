# Cookfile for the Cook Standard.
#
# Imported by the top-level Cookfile as `standard`. Chores here run
# with cwd = ./standard/, so paths are relative to this directory.
#
# `lint` and `against-tag` route through cook_modules/checks.lua, which
# is the in-repo replacement for the bash scripts that used to live in
# standard/scripts/.
#
# `against-tag` takes VERSION as a positional argument
#   cook standard.against-tag X.Y
# and defaults to the current contents of standard/VERSION when omitted.
#
# `preview` builds the docs and starts the dev server. Long-running:
# Ctrl-C to stop the server.

use checks

chore build
    pnpm build

chore lint
    checks.lint_keywords()

chore host
    pnpm host

chore preview
    pnpm build
    pnpm host

chore against-tag version=(fs.read("VERSION"):gsub("%s+$", ""))
    > checks.against_tag(version)
