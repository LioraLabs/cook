{
  "name": "cook-standard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Static-site renderer for the Cook Standard.",
  "scripts": {
    "prebuild": "tree-sitter build --wasm ../tree-sitter-cook -o public/tree-sitter-cook.wasm",
    "build": "astro build",
    "dev": "astro dev",
    "preview": "astro preview",
    "lint:keywords": "bash scripts/check-normative-keywords.sh",
    "host": "bash scripts/host.sh",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.30.0",
    "astro": "^5.0.0",
    "hast-util-from-html": "^2.0.0",
    "mdast-util-to-hast": "^13.0.0",
    "unified": "^11.0.0",
    "unist-util-visit": "^5.0.0",
    "vfile": "^6.0.3",
    "web-tree-sitter": "^0.25.0"
  },
  "devDependencies": {
    "@types/hast": "^3.0.0",
    "@types/mdast": "^4.0.0",
    "@types/node": "^22.0.0",
    "rehype": "^13.0.0",
    "rehype-parse": "^9.0.0",
    "remark": "^15.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
