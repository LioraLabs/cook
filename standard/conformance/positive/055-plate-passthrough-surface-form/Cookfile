# Standard §5.4.1: a `plate` step's output is a passthrough of its input
# list, so a downstream `$<recipe>` reference that names a plate-only
# recipe expands to that recipe's input list (or the preceding cook
# step's outputs, if there was one). The runtime contract is verified by
# cook-register/cook-luagen unit tests; this fixture pins the surface
# syntax against parse/codegen regressions.

recipe greet
    ingredients "Cookfile"
    plate { echo "hello" }

chore shout: greet
    echo "shout sees $<greet>"
