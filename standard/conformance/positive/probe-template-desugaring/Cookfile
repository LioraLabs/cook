register
    cook.probe("test:greet", {
        inputs = {},
        produce = "return { word = \"hello\" }",
    })

recipe build
    cook.add_unit({
        name = "echo",
        inputs = {},
        outputs = {"build/done.txt"},
        probes = {"test:greet"},
        command = "echo $<test:greet.word> > build/done.txt",
    })
