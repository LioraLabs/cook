recipe "ordered_sources"
    > -- CS-0079: results are concatenated in call order; within each pattern,
    > -- glob's internal order is preserved. This fixture locks the Cookfile
    > -- surface; the runtime ordering rule is verified by unit tests in
    > -- cook-lua-stdlib::fs_api::static_glob_array_order_follows_pattern_order.
    > local sys = fs.glob({"neo/sys/*.cpp", "neo/sys/posix/*.cpp"})
    > local platform = fs.glob({"neo/sys/linux/*.cpp"})
    > for _, f in ipairs(sys) do print(f) end
    > for _, f in ipairs(platform) do print(f) end
