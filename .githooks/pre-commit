#!/usr/bin/env bash
#
# Cook Standard pre-commit hook.
#
# Warns when a commit touches language-surface code without also updating
# standard/. Install with:
#     git config core.hooksPath .githooks
#
# Bypass with:
#     COOK_STANDARD_BYPASS=1 git commit ...
#
# See CONTRIBUTING.md for the spec-first rule.

set -euo pipefail

if [ "${COOK_STANDARD_BYPASS:-0}" = "1" ]; then
  exit 0
fi

staged="$(git diff --cached --name-only --diff-filter=ACMRT)"

if [ -z "$staged" ]; then
  exit 0
fi

is_language_surface() {
  case "$1" in
    # Markdown under watched paths is documentation, not language surface
    # (crate READMEs, CONFORMANCE.md). A doc-only fix must not need the
    # bypass — the bypass is for judged non-language changes to CODE.
    *.md)                         return 1 ;;
    cli/crates/cook-lang/*)       return 0 ;;
    cli/crates/cook-luagen/*)     return 0 ;;
    cli/crates/cook-register/*)   return 0 ;;
    tree-sitter-cook/grammar.js)  return 0 ;;
    tree-sitter-cook/src/*)       return 0 ;;
    standard/conformance/*)       return 0 ;;
    *)                            return 1 ;;
  esac
}

is_standard() {
  case "$1" in
    standard/*) return 0 ;;
    *)          return 1 ;;
  esac
}

touches_language=0
touches_standard=0

while IFS= read -r path; do
  [ -z "$path" ] && continue
  if is_language_surface "$path"; then
    touches_language=1
  fi
  if is_standard "$path"; then
    touches_standard=1
  fi
done <<EOF
$staged
EOF

if [ "$touches_language" = "1" ] && [ "$touches_standard" = "0" ]; then
  cat >&2 <<'MSG'
error: this commit touches language-surface code but does not update standard/.

The Cook Standard is the authoritative definition of the Cookfile language;
language-affecting changes require an update to standard/ in the same
commit. See CONTRIBUTING.md.

Staged language-surface paths:
MSG
  while IFS= read -r path; do
    [ -z "$path" ] && continue
    if is_language_surface "$path"; then
      printf '  %s\n' "$path" >&2
    fi
  done <<EOF
$staged
EOF
  cat >&2 <<'MSG'

To bypass for a non-language-affecting change (refactor, performance work,
error-message rewording), set COOK_STANDARD_BYPASS=1 for this commit.
MSG
  exit 1
fi

# Second arm: warn when E-changes.mdx grows a new CS-NNNN entry without
# growing standard/conformance/. Most language CSes ship a corpus case;
# spec-only CSes (rendering, navigation) legitimately don't, and can
# bypass this warning with COOK_STANDARD_BYPASS=1.

echanges_path="standard/src/content/docs/appendix/E-changes.mdx"
echanges_changed=0
conformance_grew=0

while IFS= read -r path; do
  [ -z "$path" ] && continue
  if [ "$path" = "$echanges_path" ]; then
    echanges_changed=1
  fi
  case "$path" in
    standard/conformance/*) conformance_grew=1 ;;
  esac
done <<EOF
$staged
EOF

if [ "$echanges_changed" = "1" ]; then
  # Only warn if the diff adds at least one new "## CS-NNNN" heading.
  added_cs="$(git diff --cached -- "$echanges_path" \
    | grep -E '^\+##[[:space:]]+CS-[0-9]{4}' || true)"
  if [ -n "$added_cs" ] && [ "$conformance_grew" = "0" ]; then
    cat >&2 <<'MSG'
warning: this commit adds a CS entry to E-changes.mdx without growing standard/conformance/.

Most language-surface CSes should ship at least one positive or negative
conformance case. Spec-only CSes (rendering plugins, doc cleanups,
navigation) legitimately do not; bypass with COOK_STANDARD_BYPASS=1.

Newly added CS heading(s):
MSG
    printf '%s\n' "$added_cs" >&2
    echo "" >&2
  fi
fi

exit 0
