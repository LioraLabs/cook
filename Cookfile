# Cookfile for the Cook project itself.
#
# Sub-projects each have their own Cookfile; this file imports them and
# wires up cross-cutting umbrella recipes.
#
# Top-level chores:
#   cook check        — pre-commit smoke test (cli build/test/conformance, ts test/conformance, standard build/lint).
#   cook bump-claim   — after a Standard cut, mirror the version into every
#                       in-repo claim site (cook-lang Rust constant + 3 markdown
#                       files + tree-sitter-cook grammar.js header, package.json
#                       description, tree-sitter.json description). Routes
#                       through cook_modules/release.lua.
#   cook release      — cut a Phase 1 host-target release: build cook, package
#                       via cook-xtask, tag, push to Gitea (mirrors to GitHub),
#                       and upload artifacts to LioraLabs/cook GitHub release.
#                       Idempotent: re-running on the same VERSION from another
#                       host appends that host's tarball + checksum line to the
#                       existing release. Routes through cook_modules/release.lua.
#                       Usage: cook --set VERSION=v0.0.1-m1 release
#
# Sub-project chores are reachable via their import alias:
#   cli.build            cli.test            cli.conformance
#   cli.version          cli.install
#   standard.build       standard.lint       standard.host
#   standard.against-tag standard.retag
#   ts.generate          ts.test             ts.conformance
#   ts.wasm              ts.nvim-install
#
# Chores that take a version (bump-claim, standard.retag, standard.against-tag)
# read VERSION from `cook <chore> --set VERSION=X.Y` and default to the
# current contents of standard/VERSION.
#
# First-time install of `cook` is documented in README.md.

import cli ./cli
import standard ./standard
import ts ./tree-sitter-cook

use release
use luarocks_phase2

chore bump-claim
    > release.bump_claim(cook.env.VERSION)

chore release
    > release.cut(cook.env.VERSION)

chore build-lua
    > luarocks_phase2.build_lua()

chore check-exports
    > luarocks_phase2.check_exports()

chore bundle-luarocks
    > luarocks_phase2.bundle_luarocks()

chore package
    > luarocks_phase2.package(cook.env.VERSION, cook.env.TARGET)

chore gate-m2: package
    > luarocks_phase2.gate_m2()

# ── Common workflow aliases ────────────────────────────────
# Forward the most-used commands to their qualified targets so the
# top-level UX stays terse. Use the qualified names directly for
# everything else.

chore build: cli.build

chore test: cli.test

chore conformance: cli.conformance

chore version: cli.version

chore install: cli.install

chore check: cli.build cli.test cli.conformance ts.test ts.conformance standard.build standard.lint
