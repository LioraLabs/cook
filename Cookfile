import cli ./cli
import standard ./standard
import ts ./tree-sitter-cook

use dist
use release

# Build variants:
#   cook build              cargo's dev profile
#   cook build @profiling   release codegen plus debug info for profilers
#
# `build` lives here rather than in cli/Cookfile because config presets resolve
# against the root Cookfile only.

config
    env.CARGO_PROFILE_ARGS = ""

# Pairs with [profile.profiling] in cli/Cargo.toml. Setting RUSTFLAGS replaces
# rather than merges with cli/.cargo/config.toml, so the overlay has to repeat
# the link arg that exports Lua symbols for C rocks.
config profiling
    env.CARGO_PROFILE_ARGS = "--profile profiling"
    local export_dynamic = host.os == "macos"
        and "-C link-arg=-Wl,-export_dynamic"
        or "-C link-arg=-rdynamic"
    env.RUSTFLAGS = export_dynamic .. " -C force-frame-pointers=yes"

# Runs from cli/ so cargo picks up cli/.cargo/config.toml, which it resolves
# from the cwd rather than from the manifest's directory.
chore build: ts.generate
    sh -c 'cd cli && exec cargo build $CARGO_PROFILE_ARGS'

# `target` is a Rust host triple and must equal the build host.
chore package version target
    > dist.package(version, target)

chore bump-claim version=(fs.read("standard/VERSION"):gsub("%s+$", ""))
    > release.bump_claim(version)

# Bumps [workspace.package], commits, tags, and pushes. Pushing the tag fires
# the release build+publish matrix in .github/workflows/release.yml.
chore release version
    > release.cut(version)
