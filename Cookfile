import cli ./cli
import standard ./standard
import ts ./tree-sitter-cook

use dist
use release

# Sub-project chores keep their namespace (`cook cli.build`) — no top-level
# single-alias forwards.

# `target` is a Rust host triple and MUST equal the build host: cargo drops the
# conditional rustflags that export Lua symbols for C rocks the moment
# --target is passed. See cook_modules/dist.lua.
chore package version target
    > dist.package(version, target)

chore bump-claim version=(fs.read("standard/VERSION"):gsub("%s+$", ""))
    > release.bump_claim(version)

# ── README generation ────────────────────────────────────────────────────
# README.md is compiled from README.source: each annotated ```cook fence
# renders to a light + dark SVG pair, then the compiler swaps fences for
# <picture> blocks. One probe record per fence — edit one snippet and only
# its two SVGs re-render before the README recompiles.

probe readme:tools
    tools { python3 }

probe readme:snippets
    ingredients "README.source" "assets/readme/code_svg.py"
    json { python3 assets/readme/code_svg.py snippets README.source }

recipe readme
    ingredients readme:snippets
    seal readme:tools
    cook "assets/readme/snippet-$<in.name>.svg" "assets/readme/snippet-$<in.name>-dark.svg" {
        python3 assets/readme/code_svg.py render README.source $<in.name> light > assets/readme/snippet-$<in.name>.svg
        python3 assets/readme/code_svg.py render README.source $<in.name> dark > assets/readme/snippet-$<in.name>-dark.svg
    }
    cook "README.md" { : $<file:README.source> $<file:assets/readme/code_svg.py> && python3 assets/readme/code_svg.py compile README.source > $<out> }
