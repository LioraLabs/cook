# Cookfile for the Cook project itself.
#
# Sub-projects each have their own Cookfile; this file imports them and
# wires up the cross-cutting umbrella + release chores.
#
# Top-level chores:
#   cook check        — pre-commit umbrella: cli build/test/conformance,
#                       ts test/conformance, standard build/lint.
#   cook package      — assemble the redistributable tarball (lua + luarocks
#                       + cook + checksums) into cli/target/dist/. Routes
#                       through cook_modules/dist.lua → dist.package.
#   cook release      — cut a host-target release: build via cook package,
#                       tag the commit, push to origin, upload tarball +
#                       checksums to the LioraLabs/cook GitHub release.
#                       Routes through cook_modules/release.lua → release.cut.
#                       Idempotent: re-running on the same VERSION from
#                       another host appends that host's tarball + checksum
#                       line to the existing release.
#                       Usage: cook --set VERSION=v0.0.1-m1 release
#   cook bump-claim   — after a Standard cut, mirror the version into
#                       every in-repo claim site (cook-lang Rust constant
#                       + 3 markdown files + tree-sitter-cook grammar.js
#                       header, package.json + tree-sitter.json description).
#                       Routes through cook_modules/release.lua → release.bump_claim.
#                       Defaults to standard/VERSION; override with
#                       cook bump-claim --set VERSION=X.Y.
#
# Sub-Cookfile chores reachable directly via their import alias:
#   cli.build            cli.test            cli.conformance
#   standard.build       standard.lint       standard.host       standard.preview
#   standard.against-tag
#   ts.generate          ts.test             ts.conformance
#   ts.wasm              ts.nvim-install
#
# Daily-loop commands like `cook cli.build` and `cook cli.test` are
# typed with their full namespace — no top-level aliases (refactor Rule 1:
# no single-alias forwards).

import cli ./cli
import standard ./standard
import ts ./tree-sitter-cook

use dist
use release

chore check: cli.build cli.test cli.conformance ts.test ts.conformance standard.build standard.lint

chore package
    > dist.package(cook.env.VERSION, cook.env.TARGET)

chore release
    > release.cut(cook.env.VERSION)

chore bump-claim
    > release.bump_claim(cook.env.VERSION)
