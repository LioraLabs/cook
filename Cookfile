import cli ./cli
import standard ./standard
import ts ./tree-sitter-cook

use dist
use release

# Build variants live in cli/Cookfile beside the crate they build (config
# presets now compose across imports, COOK-307 / §11.6):
#   cook cli.build              cargo's dev profile
#   cook cli.build @profiling   release codegen plus debug info for profilers

# `target` is a Rust host triple and must equal the build host.
chore package version target
    > dist.package(version, target)

chore bump-claim version=(fs.read("standard/VERSION"):gsub("%s+$", ""))
    > release.bump_claim(version)

# Bumps [workspace.package], commits, tags, and pushes. Pushing the tag fires
# the release build+publish matrix in .github/workflows/release.yml.
chore release version
    > release.cut(version)
