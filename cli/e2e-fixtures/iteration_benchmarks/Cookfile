config
    var.SLEEP = "0.5"

# Mode 1: One-to-one, shell block.
# N inputs => N units, each producing 1 output.
# $<in.stem> in the output pattern drives own-input iteration.
recipe one_to_one_shell
    ingredients "src/inputs/*.txt"
    cook "build/one_to_one_shell/$<in.stem>.out" {
        mkdir -p build/one_to_one_shell
        sleep $<SLEEP>
        echo "one_to_one_shell: $<in> -> $<out>" > $<out>
    }

# Mode 2: One-to-one, Lua block.
# Same iteration shape as mode 1 but the body is Lua.
# `input` / `output` are the singleton per-iteration bindings (§6.4).
recipe one_to_one_lua
    ingredients "src/inputs/*.txt"
    cook "build/one_to_one_lua/$<in.stem>.out" >{
        os.execute("mkdir -p build/one_to_one_lua")
        os.execute("sleep " .. (os.getenv("SLEEP") or "0.5"))
        local f = io.open(output, "w")
        f:write("one_to_one_lua: " .. input .. " -> " .. output .. "\n")
        f:close()
    }

# Mode 3: One-to-many, shell block.
# N inputs => N units, each producing 2 outputs.
# Both output patterns share $<in.stem> — same driver, two outputs per unit.
recipe one_to_many_shell
    ingredients "src/inputs/*.txt"
    cook "build/one_to_many_shell/$<in.stem>.a.out" "build/one_to_many_shell/$<in.stem>.b.out" {
        mkdir -p build/one_to_many_shell
        sleep $<SLEEP>
        echo "one_to_many_shell: $<in> -> $<out_1>" > $<out_1>
        echo "one_to_many_shell: $<in> -> $<out_2>" > $<out_2>
    }

# Mode 4: Many-to-one, shell block.
# All inputs => 1 unit, 1 literal output.
# $<in> expands to the space-joined full input list.
recipe many_to_one_shell
    ingredients "src/inputs/*.txt"
    cook "build/many_to_one_shell/all.out" {
        mkdir -p build/many_to_one_shell
        sleep $<SLEEP>
        echo "many_to_one_shell: $<in>" > $<out>
    }

# Mode 5: Many-to-one, Lua block — THE CS-0022 WART-FIX.
# Pre-CS-0022: a single-output Lua block iterated per input.
# Post-CS-0022: iteration is owned by the output pattern.
# A literal output pattern means exactly one unit; `inputs` in the
# Lua body sees the FULL list. Read build/many_to_one_lua/all.out to verify.
recipe many_to_one_lua
    ingredients "src/inputs/*.txt"
    cook "build/many_to_one_lua/all.out" >{
        os.execute("mkdir -p build/many_to_one_lua")
        os.execute("sleep " .. (os.getenv("SLEEP") or "0.5"))
        local f = io.open(output, "w")
        f:write("many_to_one_lua: " .. #inputs .. " inputs\n")
        for i, p in ipairs(inputs) do
            f:write("  inputs[" .. i .. "] = " .. p .. "\n")
        end
        f:close()
    }

# Mode 6: Many-to-one, multi-output, shell block.
# 1 unit, 2 literal outputs. $<out_1>/$<out_2> name them in order.
recipe many_to_one_multi_shell
    ingredients "src/inputs/*.txt"
    cook "build/many_to_one_multi_shell/all.a.out" "build/many_to_one_multi_shell/all.b.out" {
        mkdir -p build/many_to_one_multi_shell
        sleep $<SLEEP>
        echo "many_to_one_multi_shell: side-a from $<in>" > $<out_1>
        echo "many_to_one_multi_shell: side-b from $<in>" > $<out_2>
    }

# Mode 7: Many-to-one, multi-output, Lua block.
# 1 unit, 2 literal outputs. outputs[1]/outputs[2] in Lua.
recipe many_to_one_multi_lua
    ingredients "src/inputs/*.txt"
    cook "build/many_to_one_multi_lua/all.a.out" "build/many_to_one_multi_lua/all.b.out" >{
        os.execute("mkdir -p build/many_to_one_multi_lua")
        os.execute("sleep " .. (os.getenv("SLEEP") or "0.5"))
        local fa = io.open(outputs[1], "w")
        fa:write("many_to_one_multi_lua: side-a, " .. #inputs .. " inputs\n")
        fa:close()
        local fb = io.open(outputs[2], "w")
        fb:write("many_to_one_multi_lua: side-b, " .. #inputs .. " inputs\n")
        fb:close()
    }

# stage1 — driver for dep_driven.
# One-to-one over own inputs. stage2 (dep_driven) will iterate over stage1's outputs.
recipe stage1
    ingredients "src/inputs/*.txt"
    cook "build/stage1/$<in.stem>.staged" {
        mkdir -p build/stage1
        sleep $<SLEEP>
        echo "stage1: $<in>" > $<out>
    }

# Mode 8: Dep-driven (one-to-one over a dependency's outputs).
# $<stage1.stem> in the output pattern drives iteration over stage1's output list.
# Inside the body, $<in> names each stage1 output (the current iteration item).
recipe dep_driven
    cook "build/dep_driven/$<stage1.stem>.final" {
        mkdir -p build/dep_driven
        sleep $<SLEEP>
        echo "dep_driven: $<in> -> $<out>" > $<out>
    }

# libfoo — many-to-one, single output.
# Simulates archiving all inputs into one library.
recipe libfoo
    ingredients "src/inputs/*.txt"
    cook "build/lib/libfoo.a" {
        mkdir -p build/lib
        sleep $<SLEEP>
        echo "libfoo: $<in>" > $<out>
    }

# app_with_lib — cross-recipe reference inside a shell block (§5.5 / CS-0022 §3.6).
# CS-0022 extends $<NAME> substitution into { } shell blocks.
# $<libfoo> expands to libfoo's full output list (space-joined).
recipe app_with_lib
    cook "build/bin/app_with_lib" {
        mkdir -p build/bin
        sleep $<SLEEP>
        echo "app_with_lib: linked against $<libfoo>" > $<out>
    }

# Second-stage mode 1: One-to-one, shell (was a `plate` step; CS-0135
# removed plate — the un-sandboxed per-item pass is now a second, cached
# `cook` step driven by the same declared ingredients).
recipe plate_one_to_one_shell
    ingredients "src/inputs/*.txt"
    cook "build/plate_one_to_one_shell/$<in.stem>.out" {
        mkdir -p build/plate_one_to_one_shell
        sleep $<SLEEP>
        echo "plated: $<in>" > $<out>
    }
    cook "build/plate_one_to_one_shell/$<in.stem>.plated" {
        sleep $<SLEEP>
        echo "plate one-to-one: $<in>" > $<out>
    }

# Second-stage mode 2: Many-to-one, shell cook step + Lua second stage
# (was a batched `plate` step). A batched body can't be shell (CS-0130
# removed the old all-inputs placeholder; per-item/one-shot only), so
# it's a Lua block with a literal output, where `inputs` is the full
# collected source list — same shape as many_to_one_lua above.
recipe plate_many_to_one_shell
    ingredients "src/inputs/*.txt"
    cook "build/plate_many_to_one_shell/$<in.stem>.out" {
        mkdir -p build/plate_many_to_one_shell
        sleep $<SLEEP>
        echo "plated: $<in>" > $<out>
    }
    cook "build/plate_many_to_one_shell/all.report" >{
        os.execute("sleep " .. (os.getenv("SLEEP") or "0.5"))
        local f = io.open(output, "w")
        f:write("plate many-to-one inputs: " .. table.concat(inputs, " ") .. "\n")
        f:close()
    }

# Second-stage mode 3: One-shot, shell (was a one-shot `plate` step).
# Literal output, no $<in.stem> in the pattern => runs once regardless of
# the declared ingredients (same rule as test_one_shot_shell below).
recipe plate_one_shot_shell
    ingredients "src/inputs/*.txt"
    cook "build/plate_one_shot_shell/$<in.stem>.out" {
        mkdir -p build/plate_one_shot_shell
        sleep $<SLEEP>
        echo "plated: $<in>" > $<out>
    }
    cook "build/plate_one_shot_shell/.flag" {
        sleep $<SLEEP>
        echo "plate one-shot ran" > $<out>
    }

# Second-stage mode 4: One-to-one, Lua (was a `plate >{ }` step referencing
# `input`).
recipe plate_one_to_one_lua
    ingredients "src/inputs/*.txt"
    cook "build/plate_one_to_one_lua/$<in.stem>.out" {
        mkdir -p build/plate_one_to_one_lua
        sleep $<SLEEP>
        echo "plated: $<in>" > $<out>
    }
    cook "build/plate_one_to_one_lua/$<in.stem>.plated" >{
        os.execute("sleep " .. (os.getenv("SLEEP") or "0.5"))
        local f = io.open(output, "w")
        f:write("plate one-to-one lua: " .. input .. "\n")
        f:close()
    }

# Second-stage mode 5: Many-to-one, Lua (was a `plate >{ }` step
# referencing `inputs`).
recipe plate_many_to_one_lua
    ingredients "src/inputs/*.txt"
    cook "build/plate_many_to_one_lua/$<in.stem>.out" {
        mkdir -p build/plate_many_to_one_lua
        sleep $<SLEEP>
        echo "plated: $<in>" > $<out>
    }
    cook "build/plate_many_to_one_lua/all.report" >{
        os.execute("sleep " .. (os.getenv("SLEEP") or "0.5"))
        local f = io.open(output, "w")
        f:write("plate many-to-one lua: " .. #inputs .. " inputs\n")
        f:close()
    }

# Second-stage mode 6: One-shot, Lua (was a one-shot `plate >{ }` step).
recipe plate_one_shot_lua
    ingredients "src/inputs/*.txt"
    cook "build/plate_one_shot_lua/$<in.stem>.out" {
        mkdir -p build/plate_one_shot_lua
        sleep $<SLEEP>
        echo "plated: $<in>" > $<out>
    }
    cook "build/plate_one_shot_lua/.flag" >{
        os.execute("sleep " .. (os.getenv("SLEEP") or "0.5"))
        os.execute("touch " .. output)
    }

# Test mode 1: One-to-one, shell.
# $<in> iterates over cook outputs; checks each output file exists.
recipe test_one_to_one_shell
    ingredients "src/inputs/*.txt"
    cook "build/test_one_to_one_shell/$<in.stem>.out" {
        mkdir -p build/test_one_to_one_shell
        sleep $<SLEEP>
        echo "test input: $<in>" > $<out>
    }
    test { test -f $<in> }

# Test mode 2: Many-to-one, cook step shell + Lua test.
# A batched (many-to-one) test body can no longer be shell (CS-0130
# removed the old all-inputs placeholder, and plate/test shell bodies are
# per-item or one-shot only) — it moves to the Lua block form, where
# `inputs` is the full collected source list.
recipe test_many_to_one_shell
    ingredients "src/inputs/*.txt"
    cook "build/test_many_to_one_shell/all.out" {
        mkdir -p build/test_many_to_one_shell
        sleep $<SLEEP>
        echo "many-to-one: $<in>" > $<out>
    }
    test >{
        assert(#inputs > 0, "expected at least one input")
    }

# Test mode 3: One-shot, shell.
# Body references neither $<in> nor the collected inputs; runs once
# unconditionally.
recipe test_one_shot_shell
    ingredients "src/inputs/*.txt"
    cook "build/test_one_shot_shell/all.out" {
        mkdir -p build/test_one_shot_shell
        sleep $<SLEEP>
        echo "one-shot done" > $<out>
    }
    test { true }

# Test mode 4: One-to-one, Lua.
# `input` iterates over cook outputs; asserts each file is readable.
recipe test_one_to_one_lua
    ingredients "src/inputs/*.txt"
    cook "build/test_one_to_one_lua/$<in.stem>.out" {
        mkdir -p build/test_one_to_one_lua
        sleep $<SLEEP>
        echo "test lua input: $<in>" > $<out>
    }
    test >{
        local f = io.open(input, "r")
        assert(f, "file not readable: " .. input)
        f:close()
    }

# Test mode 5: Many-to-one, Lua.
# `inputs` gives the full list; asserts count is greater than zero.
recipe test_many_to_one_lua
    ingredients "src/inputs/*.txt"
    cook "build/test_many_to_one_lua/all.out" {
        mkdir -p build/test_many_to_one_lua
        sleep $<SLEEP>
        echo "many-to-one lua" > $<out>
    }
    test >{
        assert(#inputs > 0, "expected at least one input")
    }

# Test mode 6: One-shot, Lua.
# No source binding; runs once unconditionally.
recipe test_one_shot_lua
    ingredients "src/inputs/*.txt"
    cook "build/test_one_shot_lua/all.out" {
        mkdir -p build/test_one_shot_lua
        sleep $<SLEEP>
        echo "one-shot lua done" > $<out>
    }
    test >{
        assert(true)
    }

# benchmarks — orchestrator.
# Lists every mode recipe as a dependency.
recipe benchmarks: one_to_one_shell one_to_one_lua one_to_many_shell many_to_one_shell many_to_one_lua many_to_one_multi_shell many_to_one_multi_lua dep_driven app_with_lib plate_one_to_one_shell plate_many_to_one_shell plate_one_shot_shell plate_one_to_one_lua plate_many_to_one_lua plate_one_shot_lua test_one_to_one_shell test_many_to_one_shell test_one_shot_shell test_one_to_one_lua test_many_to_one_lua test_one_shot_lua
    cook "build/benchmarks.txt" {
        mkdir -p build
        date > $<out>
        echo "All iteration modes completed at $(date)" >> $<out>
    }

# chore clean — wipe build/ and .cook cache for re-runs.
chore clean
    rm -rf build .cook
