# Frontend project. Two test recipes — one passing, one mixed.

recipe build
    cook "build/web.bundle" {
        mkdir -p build
        echo "web bundle" > $<out>
    }

recipe unit: build
    test { true }
    test { echo "unit ok"; true }

recipe e2e: build
    test { test -s $<build> }
    test { exit 1 }
