# NOTE (COOK-66 / COOK-69): both probes stay on the register-phase cook.probe()
# API for two reasons:
#   1. demo:cc-path declares env/tools fingerprint inputs, which the native
#      `probe` declaration does not yet express (deferred to COOK-66).
#   2. demo:cc-version has a hyphen in its key second-segment ("cc-version"),
#      which is not admitted by the native probe header's bare-identifier scanner
#      (only [a-zA-Z0-9_] is valid in a probe key segment). Until the scanner is
#      extended (or the probe is renamed), the native form cannot express this key.
# See examples/probe-cache-share for the native `probe` surface.
register
    cook.probe("demo:cc-path", {
        inputs = { env = {"PATH"}, tools = {"cc"} },
        produce = [[
            local path = cook.sh("which cc"):gsub("%s+$", "")
            return { path = path }
        ]],
    })

    cook.probe("demo:cc-version", {
        inputs = { requires = {"demo:cc-path"} },
        produce = [[
            local cc = cook.cache.get("demo:cc-path").path
            local ver = cook.sh(cc .. " -dumpversion 2>&1"):gsub("%s+$", "")
            return { version = ver }
        ]],
    })

recipe build
    cook.add_unit({
        name    = "print-version",
        inputs  = {},
        outputs = {"build/version.txt"},
        probes  = {"demo:cc-version"},
        command = "mkdir -p build && echo $<demo:cc-version.version> > build/version.txt",
    })
    test { cat build/version.txt }
