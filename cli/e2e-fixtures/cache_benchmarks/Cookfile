# Cache Benchmarks — verification fixture for the SHI-140 cache cloud-readiness work.
#
# Each recipe exercises one cache invariant. See README.md and verify.sh
# for the matrix of scenarios and the expected hit/miss behavior.
#
# Quick reference:
#   cook demo             — fresh build, all steps execute
#   cook demo             — second invocation, all hits (no-op rebuild)
#   touch src/greet.c && cook demo  — only `greet` and `demo` rebuild; `util` stays cached
#   CFLAGS=-O3 cook demo  — `greet` and `util` rebuild (both consume $<CFLAGS>); `sister` stays cached
#   HOME=/elsewhere cook sister     — no rebuild (HOME is denylisted)
#   cook pair             — multi-output recipe; each output uploads as its
#                            own artifact (addendum §5.1)
#   cook mono             — exercises the imported lib/ Cookfile (addendum §6)
#   cook clean            — wipe build/

config
    var.CFLAGS = "-O0 -g"
    var.CC = "gcc"

# Two overlays for the CFLAGS-toggle scenario.
# Invoke with `cook debug demo` or `cook release demo`.
config debug
    var.CFLAGS = "-O0 -g"

config release
    var.CFLAGS = "-O3"

# Imported sub-cookfile for SHI-140 addendum monorepo cache verification.
# `lib.lib_build` is referenced from the demo recipe.
import lib ./lib

# greet.c — consumes $<CFLAGS> via Layer 2 inference
recipe greet
    ingredients "src/greet.c"
    cook "build/greet.o" {
        mkdir -p build
        $<CC> $<CFLAGS> -c $<in> -o $<out>
    }

# util.c — also consumes $<CFLAGS>; provides main()
recipe util
    ingredients "src/util.c"
    cook "build/util.o" {
        mkdir -p build
        $<CC> $<CFLAGS> -c $<in> -o $<out>
    }

# Link step — does NOT consume $<CFLAGS> via inference
# but DOES invoke the gcc binary directly. Its context_hash captures
# the linker's binary identity through the same tool-content hash.
# `$<lib.lib_build>` is a cross-Cookfile body reference (§7.3): codegen
# lowers it to cook.dep_output("lib.lib_build") after Phase 7.
recipe demo:
    cook "build/demo" {
        $<CC> $<greet> $<util> $<lib.lib_build> -o $<out>
    }

# `mono` exercises the imported lib alongside demo. Used by the SHI-140
# addendum verify.sh scenarios 10-11 to assert cross-cookfile cache
# behavior (DAG ordering + per-recipe caching across cookfile boundaries).
# lib.lib_build is now a transitive dep of demo, so mono just aliases demo.
recipe mono: demo

# Sister recipe — does NOT consume $<CFLAGS>. Used to verify env-key
# isolation: when the user toggles CFLAGS, this step's cache survives
# because $<CFLAGS> is not in its consulted_env_keys set.
recipe sister
    ingredients "src/sister.txt"
    cook "build/sister.out" {
        mkdir -p build
        cat $<in> > $<out>
    }

# Multi-output recipe — every output uploads as its own artifact via the
# 2026-05-02 addendum's per-output artifact_key (spec §5.1). Both foo.txt
# and bar.txt are independently addressable in the LocalBackend store and
# can be restored on cache hit (verify.sh scenarios 13-14, 19).
recipe pair
    ingredients "tools/genpair.sh"
    cook "build/pair/foo.txt" "build/pair/bar.txt" {
        mkdir -p build/pair
        /bin/sh tools/genpair.sh build/pair/foo.txt build/pair/bar.txt
    }

chore clean
    rm -rf build .cook/cache lib/build lib/.cook/cache
