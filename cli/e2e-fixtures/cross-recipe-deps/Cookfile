# Cross-recipe dependency example — demonstrates $<dep> references.
#
# Recipes reference other recipes' outputs via $<recipe_name> syntax.
# The engine infers dependency edges and wires fine-grained unit-level
# dependencies automatically — no explicit : dep syntax needed.

recipe libmath
    ingredients "src/math/*.c"
    cook "build/obj/math/$<in.stem>.o" {
        mkdir -p build/obj/math && gcc -c $<in> -Isrc -o $<out>
    }
    cook "build/lib/libmath.a" {
        mkdir -p build/lib && ar rcs $<out> $<in>
    }

recipe libstr
    ingredients "src/str/*.c"
    cook "build/obj/str/$<in.stem>.o" {
        mkdir -p build/obj/str && gcc -c $<in> -Isrc -o $<out>
    }
    cook "build/lib/libstr.a" {
        mkdir -p build/lib && ar rcs $<out> $<in>
    }

recipe app
    ingredients "src/main.c"
    cook "build/obj/main.o" {
        mkdir -p build/obj && gcc -c $<in> -Isrc -o $<out>
    }
    cook "build/bin/app" {
        mkdir -p build/bin && gcc -o $<out> $<in> $<libmath> $<libstr>
    }

recipe run: app
    test { build/bin/app }

chore clean
    rm -rf build .cook
