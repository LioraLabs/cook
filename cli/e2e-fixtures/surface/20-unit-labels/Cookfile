recipe twolines
    cook "out/first.txt" { echo first > $<out>; echo MARKER_FIRST_LINE }
    cook "out/second.txt" { cat $<in> > $<out>; echo MARKER_SECOND_LINE }

recipe fanout
    ingredients "src/*.txt"
    cook "out/$<in.stem>.done" {
        echo working
        cat $<in> > $<out>
    }

probe demo:tag
    { echo demo-value }

recipe probed
    cook "out/probed.txt" { echo "$<demo:tag>" > $<out> }
