probe demo:nonce
    >{
        local stamp = cook.sh("date +%s%N"):gsub("%s+$", "")
        return { stamp = stamp }
    }

recipe build
    cook.add_unit({
        name    = "record",
        inputs  = {},
        outputs = {"build/probed.txt"},
        probes  = {"demo:nonce"},
        command = "mkdir -p build && echo $<demo:nonce.stamp> > build/probed.txt",
    })
    test { cat build/probed.txt }
