# Regenerates the tracked parser before cargo compiles it; cached on grammar.js.
import ts //tree-sitter-cook

chore build: ts.generate
    cargo build --manifest-path Cargo.toml

# Sourceless on purpose: cargo's real input set spans crates/, e2e-fixtures/
# and //standard/conformance/, and cargo is already incremental.
recipe test: ts.generate
    test { cargo test --manifest-path Cargo.toml }

# Subsets of `test` for a targeted loop; the recipe above already covers both.
chore conformance
    cargo test --manifest-path Cargo.toml -p cook-lang --test conformance

chore e2e
    cargo test --manifest-path Cargo.toml -p cook-cli --test surface_conformance
