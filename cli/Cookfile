# Cookfile for the Rust CLI / parser.
#
# Imported by the top-level Cookfile as `cli`. Chores here run with cwd
# = ./cli/, so paths are relative to this directory.

chore build
    cargo build --manifest-path Cargo.toml

chore test
    cargo test --manifest-path Cargo.toml

chore conformance
    cargo test --manifest-path Cargo.toml -p cook-lang --test conformance

chore version
    cargo build --manifest-path Cargo.toml --bin cook
    @target/debug/cook --version

chore install
    cargo install --locked --path crates/cook-cli
