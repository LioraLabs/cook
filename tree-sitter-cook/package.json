{
  "name": "tree-sitter-cook",
  "version": "0.14.0",
  "description": "Tree-sitter grammar for the Cook build system DSL (claims Cook Standard v0.14)",
  "license": "MIT",
  "main": "bindings/node",
  "tree-sitter": [
    {
      "scope": "source.cook",
      "file-types": ["cook"],
      "first-line-regex": "^#.*[Cc]ookfile",
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm"
    }
  ],
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter test",
    "conformance": "node scripts/conformance.mjs",
    "check": "tree-sitter generate && tree-sitter test && node scripts/conformance.mjs"
  },
  "dependencies": {
    "node-addon-api": "^8.3.1",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.25.10"
  }
}
