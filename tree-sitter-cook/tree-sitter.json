{
  "grammars": [
    {
      "name": "cook",
      "camelcase": "Cook",
      "scope": "source.cook",
      "path": ".",
      "file-types": ["cook"],
      "first-line-regex": "^#.*[Cc]ookfile",
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm"
    }
  ],
  "metadata": {
    "version": "0.12.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Cook build system DSL (claims Cook Standard v0.12)",
    "links": {
      "repository": "https://github.com/peppapig450/cook"
    }
  }
}
