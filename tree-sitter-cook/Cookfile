# Cookfile for tree-sitter-cook.
#
# Imported by the top-level Cookfile as `ts`. Recipes/chores here run with cwd
# = ./tree-sitter-cook/, so paths are relative to this directory.
#
# `wasm` writes into ../standard/public/ because the rendered Standard
# bundles the wasm parser for in-browser code highlighting.

config
    cook.env.NVIM_SITE = cook.env.NVIM_SITE or (os.getenv("HOME") .. "/.local/share/nvim/site")

recipe generate
    ingredients "grammar.js"
    cook "src/parser.c" {
        tree-sitter generate
    }

chore test
    tree-sitter test

chore conformance
    node scripts/conformance.mjs

recipe wasm: generate
    ingredients "grammar.js" "src/parser.c" "src/scanner.c"
    cook "../standard/public/tree-sitter-cook.wasm" {
        mkdir -p ../standard/public && tree-sitter build --wasm . -o $<out>
    }

recipe nvim-parser: generate
    ingredients "src/parser.c" "src/scanner.c"
    cook "build/parser/cook.so" {
        mkdir -p build/parser
        tree-sitter build . -o $<out>
    }

chore nvim-install: nvim-parser
    mkdir -p $NVIM_SITE/parser
    cp $<nvim-parser> $NVIM_SITE/parser/cook.so
    echo "installed parser → $NVIM_SITE/parser/cook.so"
    bash scripts/clean-stale-nvim-parsers.sh
    bash scripts/install-nvim-queries.sh
