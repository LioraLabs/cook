config
    cook.env.NVIM_SITE = cook.env.NVIM_SITE or (os.getenv("HOME") .. "/.local/share/nvim/site")

# One `generate` run produces all three; declaring only parser.c let
# node-types.json drift behind grammar.js unnoticed. src/tree_sitter/*.h
# tracks the CLI version, not grammar.js, so it stays undeclared.
recipe generate
    ingredients "grammar.js"
    cook "src/parser.c" "src/node-types.json" "src/grammar.json" {
        tree-sitter generate
    }

recipe test
    ingredients "test/corpus/*.txt"
    test { : $<generate> && tree-sitter test }

recipe conformance
    ingredients "scripts/conformance.mjs"
    test { : $<generate> && node scripts/conformance.mjs }

# Writes into ../standard/public/ because the rendered Standard bundles the
# wasm parser for in-browser code highlighting.
recipe wasm: generate
    ingredients "grammar.js" "src/parser.c" "src/scanner.c"
    cook "../standard/public/tree-sitter-cook.wasm" {
        mkdir -p ../standard/public && tree-sitter build --wasm . -o $<out>
    }

recipe nvim-parser: generate
    ingredients "src/parser.c" "src/scanner.c"
    cook "build/parser/cook.so" {
        mkdir -p build/parser
        tree-sitter build . -o $<out>
    }

# The Rust binding compiles the generated parser, so a grammar.js edit has to
# reach cargo — depending on `generate` is what carries it. Sealed rather than
# declared as ingredients because nothing here consumes $<in>: these are a
# fingerprint, not an iteration driver.
probe rust:tools
    tools { cargo cc }

probe rust:files
    files { "bindings/rust/*.rs" "src/*.c" "src/tree_sitter/*.h" "src/node-types.json" "queries/*.scm" "Cargo.toml" "Cargo.lock" }

recipe rust: generate
    seal rust:tools rust:files
    test { cargo test --manifest-path Cargo.toml }

# src/ is generated but tracked, and the pre-commit hook does not watch it.
# This is what keeps the committed bytes in step with grammar.js — and with the
# CLI version, since generated output is not stable across tree-sitter releases.
#
# A recipe, not a chore, so `cook test` runs it: as a chore it never ran in CI,
# which is how committed bytes generated by an undeclared CLI version reached
# main. Sourceless on purpose — it asserts a property of the working tree, not
# of declared inputs, so a cache hit could hide real drift.
recipe check-generated
    test { tree-sitter generate; git diff --exit-code -- src/ || (echo "src/ is stale — run 'cook ts.generate' and commit the result" >&2; exit 1) }

chore nvim-install: nvim-parser
    mkdir -p $NVIM_SITE/parser
    cp $<nvim-parser> $NVIM_SITE/parser/cook.so
    echo "installed parser → $NVIM_SITE/parser/cook.so"
    bash scripts/clean-stale-nvim-parsers.sh
    bash scripts/install-nvim-queries.sh
