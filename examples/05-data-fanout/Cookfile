# 05 — data-driven fan-out.
#
# The build's shape comes from DATA, not from files on disk: a JSON
# manifest lists services, a probe chain enriches the records, and the
# recipe fans out one unit per record. Add a service to the manifest and
# exactly one new unit runs; everything already built stays cached.
#
# This is the shape for any "N inputs, same treatment" job whose N lives
# in data: eval suites over test cases, renders over scenes, configs over
# environments, LLM calls over prompts.
#
# Try:
#   cook render              # one config per service in the manifest
#   cook render              # all cached
#   #   ...add a service to data/services.json...
#   cook render              # ONLY the new service builds
#   cook summary             # per-member join across recipes
#   cook why render          # each member's cache key, attributed

# Layer 1 — read the manifest. `ingredients` declares the file input, so
# editing the manifest re-fingerprints this probe and everything downstream.
probe services_raw
    ingredients "data/services.json"
    json { cat data/services.json }

# Layer 2 — enrich each record in Lua (a probe can depend on a probe;
# cook resolves the chain in order before the recipe fans out).
probe services: services_raw
    >{
        local out = {}
        for _, svc in ipairs(cook.probes.get("services_raw")) do
            table.insert(out, {
                name     = svc.name,
                url      = "http://localhost:" .. svc.port,
                replicas = svc.replicas,
            })
        end
        return out
    }

# One unit per record. `$<in.FIELD>` reads the record's fields.
recipe render
    ingredients services
    cook "build/$<in.name>.conf" {
        printf 'service  = %s\nurl      = %s\nreplicas = %s\n' \
            "$<in.name>" "$<in.url>" "$<in.replicas>" > $<out>
    }

# A second recipe iterating the SAME source can join the first one
# per-member: `$<render[]>` is "render's output for THIS member".
recipe summary: render
    ingredients services
    cook "build/summary/$<in.name>.txt" {
        printf '== %s ==\n' "$<in.name>" > $<out>
        cat $<render[]> >> $<out>
    }

chore clean
    rm -rf build
