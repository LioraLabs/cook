# 09 — deploys are chores.
#
# `cook` steps PRODUCE artifacts and must be reproducible — they run
# sandboxed and cached. `chore` steps are the un-sandboxed escape hatch:
# plain indented shell lines that always run and are deliberately NOT
# cached (they may touch $HOME, a server, a device) — the natural shape
# for a deploy.
#
# Here the "device" is a local directory. In real Cookfiles the body is
# the same shape with a real transport, e.g. one of:
#     scp $<site> deploy@host:/var/www/
#     adb push $<apk> /data/local/tmp/
#     aws s3 sync build/site "s3://my-bucket"
#
# Try:
#   cook release             # build once, then push
#   cook release             # site cached; the push re-runs (it's a side
#                            # effect — cook can't know the device state)
#   cook menu

recipe site
    ingredients "pages/*.md"
    cook "build/$<in.stem>.html" { sed 's|^# \(.*\)|<h1>\1</h1>|' $<in> > $<out> }

chore release: site
    mkdir -p ./device
    cp $<site> ./device/
    echo "released $(ls device | wc -l) page(s) to ./device"

chore clean
    rm -rf build device
