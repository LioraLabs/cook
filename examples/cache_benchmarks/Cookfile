# Cache Benchmarks — verification fixture for the SHI-140 cache cloud-readiness work.
#
# Each recipe exercises one cache invariant. See README.md and verify.sh
# for the matrix of scenarios and the expected hit/miss behavior.
#
# Quick reference:
#   cook demo             — fresh build, all steps execute
#   cook demo             — second invocation, all hits (no-op rebuild)
#   touch src/greet.c && cook demo  — only `greet` and `demo` rebuild; `util` stays cached
#   CFLAGS=-O3 cook demo  — `greet` and `util` rebuild (both consume {CFLAGS}); `sister` stays cached
#   HOME=/elsewhere cook sister     — no rebuild (HOME is denylisted)
#   cook pair             — multi-output recipe; v3 uploads only the first output
#                            (documented limitation, will be fixed in a follow-up)
#   cook clean            — wipe build/

config
    env.CFLAGS = "-O0 -g"
    env.CC = "gcc"

# Two overlays for the CFLAGS-toggle scenario.
# Invoke with `cook debug demo` or `cook release demo`.
config debug
    env.CFLAGS = "-O0 -g"

config release
    env.CFLAGS = "-O3"

# greet.c — consumes {CFLAGS} via Layer 2 inference
recipe greet
    ingredients "src/greet.c"
    cook "build/greet.o" using {
        mkdir -p build
        {CC} {CFLAGS} -c {all} -o {out}
    }

# util.c — also consumes {CFLAGS}; provides main()
recipe util
    ingredients "src/util.c"
    cook "build/util.o" using {
        mkdir -p build
        {CC} {CFLAGS} -c {all} -o {out}
    }

# Link step — does NOT consume {CFLAGS} via inference
# but DOES invoke the gcc binary directly. Its context_hash captures
# the linker's binary identity through the same tool-content hash.
recipe demo
    cook "build/demo" using {
        {CC} {greet} {util} -o {out}
    }

# Sister recipe — does NOT consume {CFLAGS}. Used to verify env-key
# isolation: when the user toggles CFLAGS, this step's cache survives
# because {CFLAGS} is not in its consulted_env_keys set.
recipe sister
    ingredients "src/sister.txt"
    cook "build/sister.out" using {
        mkdir -p build
        cat {all} > {out}
    }

# Multi-output recipe — DOCUMENTED v3 LIMITATION.
#
# The executor's cloud_key + Backend::put logic uploads only the FIRST
# output's bytes (spec §2 non-goals: "v3 limitation: multi-output steps
# upload only the first output bytes; manifest-style multi-output upload
# is a follow-up").
#
# Local cache works correctly — both foo.txt and bar.txt are tracked in
# the StepEntry's `outputs` list, and a local rebuild check sees both.
# But if a teammate cache-hits this entry from a future CloudBackend,
# they receive bytes for foo.txt only; bar.txt would be missing on disk
# and any downstream step consuming it would break.
#
# A follow-up will introduce a manifest-style upload that captures all
# outputs; until then, this recipe is the canonical reproducer.
recipe pair
    ingredients "tools/genpair.sh"
    cook "build/pair/foo.txt" "build/pair/bar.txt" using {
        mkdir -p build/pair
        /bin/sh tools/genpair.sh build/pair/foo.txt build/pair/bar.txt
    }

chore clean
    rm -rf build .cook/cache
