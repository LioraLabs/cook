use cook_cc

register
    cook_cc.toolchain({ standard = "c99" })

    local raylib_config = cook_cc.config_header(
        "raylib-src/src/config.h.in",
        "build/raylib-src/config.h",
        {
            HAVE_STDINT_H            = cook_cc.checks.has_header("stdint.h"),
            HAVE_STRDUP              = cook_cc.checks.has_function("strdup", { includes = { "string.h" } }),
            RAYLIB_VERSION           = "5.5",
            SUPPORT_MODULE_RCORE     = true,
            SUPPORT_MODULE_RSHAPES   = false,
            SUPPORT_MODULE_RTEXTURES = false,
            SUPPORT_QUADS_DRAW_MODE  = true,
            SUPPORT_FILEFORMAT_PNG   = false,
        }
    )

    cook_cc.bin("game", {
        sources  = { "src/main.c" },
        includes = { "build/raylib-src", "raylib-src/src" },
        requires = { raylib_config },
    })
