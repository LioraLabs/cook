# 07 — tests are steps.
#
# A `test` step declares a check. Tests run with the build, get cached
# like build steps (an unchanged, passing test does not re-run), and have
# their own runner UX under `cook test`. Tests auto-name (from the recipe
# and source line) and always run to completion — there are no modifiers.
#
# `check` shows both test shapes:
#   - one-to-one: `ingredients "tests/*.sh"` + `test { ./$<in> }` runs
#     every script under tests/ as its own test, one unit per script.
#   - naked one-shot: a single `test { ... }` with no iteration source.
#     `!` inverts a check that expects failure (no more `should_fail`).
#
# Try:
#   cook check               # build the artifact, run its checks
#   cook check               # everything cached, tests included
#   cook test                # the dedicated runner (per-test output,
#                            #   failures listed, exit code honest)
#   cook test --rerun-failed # after a red run: only the failures

recipe app
    ingredients "src/greeting.txt"
    cook "out/app.txt" { tr 'a-z' 'A-Z' < $<in> > $<out> }

recipe check: app
    ingredients "tests/*.sh"
    test { ./$<in> }
    test { ! grep -q lowercase $<app> }

chore clean
    rm -rf out
