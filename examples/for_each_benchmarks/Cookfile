# В§8.3 for_each Benchmarks (COOK-63 / CS-0091)
# Uses the native `probe` DSL (COOK-69).
#
# Exercises every `for_each` data-member source form and every per-member
# consumer (`cook`, `plate`, `test`). `for_each` is the data-driven counterpart
# to `ingredients`: it drives one work unit per data member rather than per
# filesystem path, with the current member bound as `item` / `$<item>` /
# `$<item.FIELD>`.
#
# SCOPE NOTE вЂ” COOK-63 lands the parser + codegen. The register-time runtime
# these recipes need (the В§22.5.9 probe pre-pass that materialises an array
# probe value before registration, the register-time `$(cmd)` capture, and the
# whole-member `cook.member_to_string` rendering) is the COOK-64 slice. Until
# then, verify with the transpiler:
#
#   cook emit-lua            # prints the generated register-phase fan-out Lua
#   ./verify.sh              # asserts the codegen shape of every recipe
#
# Once COOK-64 lands, the recipes below run end-to-end as written (commands are
# POSIX-portable on purpose). Wipe build/ between runs with `cook clean`.

# Array-shaped probe value: one record per card (В§22.5.4, В§22.5.9).
probe cards
    ingredients "data/cards.json"
    produce as json { cat data/cards.json }

# Object whose `items` field is the array вЂ” consumed via `catalog:items`.
probe catalog
    ingredients "data/catalog.json"
    produce as json { cat data/catalog.json }

# Test-case records.
probe cases
    ingredients "data/cases.json"
    produce as json { cat data/cases.json }

# в”Ђв”Ђ Source form 1: probe key, cook consumer в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# One cook unit per card record; `$<item.id>` drives the output path,
# `$<item.name>` interpolates into the body. (Canonical В§8.3 Example 8.3.1.)
recipe cards_cook
    for_each cards
    cook "build/cards/$<item.id>.txt" using {
        mkdir -p build/cards
        printf '%s\n' "$<item.name>" > $<out>
    }

# в”Ђв”Ђ Source form 2: probe key:field, cook consumer в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# `for_each catalog:items` iterates the array at the probe value's `items`
# field (В§22.5.9). The bare `$<item>` renders the whole member.
recipe catalog_cook
    for_each catalog:items
    cook "build/catalog/$<item.id>.json" using {
        mkdir -p build/catalog
        printf '%s\n' '$<item>' > $<out>
    }

# в”Ђв”Ђ Source form 3: $(cmd) NDJSON capture (default), plate consumer в”Ђв”Ђв”Ђв”Ђ
# Each stdout line is JSON-decoded into a record; one plate (side-effect)
# unit per host. Plates declare no output (В§8.3 Example 8.3.2).
recipe deploy
    for_each $(cat data/hosts.ndjson)
    plate { echo "deploy $<item.user>@$<item.host>" }

# в”Ђв”Ђ Source form 4: $(cmd) `as lines` capture, cook consumer в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# `as lines` disables JSON decoding: each `ls` output line is a raw-string
# member. The bare `$<item>` is that filename.
recipe render
    for_each $(ls posts) as lines
    cook "build/html/$<item>.html" using {
        mkdir -p build/html
        printf '<article>%s</article>\n' "$<item>" > $<out>
    }

# в”Ђв”Ђ Source form 5: probe key, test consumer в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# One test unit per case record; the member fields drive the assertion.
recipe eval
    for_each cases
    test { [ "$<item.input>" = "$<item.expect>" ] }
