# §8.3 ingredients <probe> Benchmarks (COOK-63 / CS-0091)
# Uses the native `probe` DSL (COOK-69).
#
# Exercises `ingredients <probe>` data-member fan-out across every per-member
# consumer (`cook`, `plate`, `test`). `ingredients <probe>` is the data-driven
# counterpart to `ingredients "glob"`: it drives one work unit per data member
# rather than per filesystem path, with the current member bound as `item` /
# `$<in>` / `$<in.FIELD>`.
#
# SCOPE NOTE — COOK-63 lands the parser + codegen. The register-time runtime
# these recipes need (the §22.5.9 probe pre-pass that materialises an array
# probe value before registration and the whole-member `cook.member_to_string`
# rendering) is the COOK-64 slice. Until then, verify with the transpiler:
#
#   cook emit-lua            # prints the generated register-phase fan-out Lua
#   ./verify.sh              # asserts the codegen shape of every recipe
#
# Once COOK-64 lands, the recipes below run end-to-end as written (commands are
# POSIX-portable on purpose). Wipe build/ between runs with `cook clean`.

# Array-shaped probe value: one record per card (§22.5.4, §22.5.9).
probe cards
    ingredients "data/cards.json"
    produce as json { cat data/cards.json }

# Object whose `items` field is the array — consumed via `catalog:items`.
probe catalog
    ingredients "data/catalog.json"
    produce as json { cat data/catalog.json }

# Test-case records.
probe cases
    ingredients "data/cases.json"
    produce as json { cat data/cases.json }

# ── Source form 1: probe key, cook consumer ───────────────────────────
# One cook unit per card record; `$<in.id>` drives the output path,
# `$<in.name>` interpolates into the body. (Canonical §8.3 Example 8.3.1.)
recipe cards_cook
    ingredients cards
    cook "build/cards/$<in.id>.txt" using {
        mkdir -p build/cards
        printf '%s\n' "$<in.name>" > $<out>
    }

# ── Source form 2: probe key:field, cook consumer ─────────────────────
# `ingredients catalog:items` iterates the array at the probe value's `items`
# field (§22.5.9). The bare `$<in>` renders the whole member.
recipe catalog_cook
    ingredients catalog:items
    cook "build/catalog/$<in.id>.json" using {
        mkdir -p build/catalog
        printf '%s\n' '$<in>' > $<out>
    }

# ── Source form 3: probe key, test consumer ───────────────────────────
# One test unit per case record; the member fields drive the assertion.
recipe eval
    ingredients cases
    test { [ "$<in.input>" = "$<in.expect>" ] }
