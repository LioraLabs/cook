# Cmd-test inferred-deps fixture for App. E.10.
#
# `verify_prepare`'s test body references `{prepare}`. Pre-fix, `cook --test`
# passed `&BTreeMap::new()` to the wave grouper, which registered verify_prepare
# alone and errored at codegen-resolve time with "recipe 'prepare' has no
# terminal output (not registered or has no cook steps)". Post-fix, cmd_test
# calls compute_single_inferred_deps, the wave grouper pulls `prepare` into the
# same wave with prepare-then-verify_prepare ordering, and cook.dep_output
# resolves to prepare's terminal output at registration time.
#
# Use --jobs 1 when invoking, since add_test does not yet propagate
# step_group_dep_refs into unit-DAG dep edges (separate gap, not E.10).

recipe prepare
    ingredients "src/data.txt"
    cook "build/prepare.out" using {
        mkdir -p build && cp {all} {out}
    }

recipe verify_prepare
    test {
        test -f {prepare}
    }

chore clean
    rm -rf build .cook
