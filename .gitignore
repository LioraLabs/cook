# Secrets / local env — never commit
.env
.env.*
!.env.example
**/.env
**/.env.*

# Rust
target/

# Node
node_modules/
dist/

# Cook artifacts: ignore everything inside .cook/ EXCEPT the checked-in
# cloud config (.cook/cloud.toml carries project_id and cache.ignore_env
# per spec §9 and is meant to be tracked).
.cook/**
**/.cook/**
**/cook_modules/**
!**/.cook/
!**/.cook/cloud.toml
build/
bin/
# Vendored luarocks ships its own src/bin/ and src/luarocks/build/ trees
# (and tests/fixtures use bin/ directories). Don't let the project-wide
# build/ + bin/ ignore rules silently drop them — that's what caused
# Phase 2 M2.4 to fail on macOS the first time around.
!cli/vendored/luarocks-*/**/bin/
!cli/vendored/luarocks-*/**/bin/**
!cli/vendored/luarocks-*/**/build/
!cli/vendored/luarocks-*/**/build/**

# IDE
.idea/
.vscode/

# OS
.DS_Store

# Superpowers
.superpowers/
.worktrees/
docs/superpowers/

# Claude Code per-repo config: personal settings stay local, but shared
# skills under .claude/skills/ are tracked so the team picks them up.
.claude/*
!.claude/skills/

# Canopy
.canopy/

# luarocks pack outputs (Phase 3 cook_smoke fixture and future rocks)
rocks/*/*-*.src.rock

# Project-local luarocks tree populated by `cook modules add`. Pinned by
# cook.lock + the registry, so this is build output, not source. Top-level
# user-authored lua files in cook_modules/ stay tracked.
cook_modules/lib/

# cmake-compat finder (cook_cc §9.2.3.8.1) shells out to `cmake --find-package`,
# which side-effects a CMakeFiles/ directory in the caller's cwd. Build output.
CMakeFiles/
