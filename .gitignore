# Rust
target/

# Node
node_modules/
dist/

# Cook artifacts: ignore everything inside .cook/ EXCEPT the checked-in
# cloud config (.cook/cloud.toml carries project_id and cache.ignore_env
# per spec §9 and is meant to be tracked).
.cook/**
**/.cook/**
!**/.cook/
!**/.cook/cloud.toml
build/
bin/
# Vendored luarocks ships its own src/bin/ and src/luarocks/build/ trees
# (and tests/fixtures use bin/ directories). Don't let the project-wide
# build/ + bin/ ignore rules silently drop them — that's what caused
# Phase 2 M2.4 to fail on macOS the first time around.
!cli/vendored/luarocks-*/**/bin/
!cli/vendored/luarocks-*/**/bin/**
!cli/vendored/luarocks-*/**/build/
!cli/vendored/luarocks-*/**/build/**

# IDE
.idea/
.vscode/

# OS
.DS_Store

# Superpowers
.superpowers/
.worktrees/
docs/superpowers/

# Canopy
.canopy/
